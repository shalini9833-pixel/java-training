import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int i,n;
        Scanner s=new Scanner(System.in);
        n=s.nextInt();
        for(i=1;i<=n;i++)
        {
            if(i%2==0)
            {
                System.out.print(i+" ");
            }
        }
    }
}
